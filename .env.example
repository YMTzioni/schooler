PORT=3030
FRONTEND_ORIGIN=http://localhost:5173
NODE_ENV=development

# Production (Render / Vercel): set FRONTEND_ORIGIN to your public URL
# FRONTEND_ORIGIN=https://schooler.vercel.app
# NODE_ENV=production
# USE_PUBPROXY=true

# Local: npm run dev  →  API on :3030 + Vite on :5173
# Production host:   npm run build && NODE_ENV=production npm run start:prod

# Schooler API — https://api.schooler.biz
# Swagger: https://app.swaggerhub.com/apis/Responder/SchoolerAPI/1.0.0
#
# שלב 1 — User ID + User Secret:
#   אימייל Schooler + מפתח API (מפתחות Schooler / תמיכה)
#
# שלב 2 — Client ID + Secret (מתמיכת Schooler):
#   פנו ל-support@responder.co.il — בדרך כלל נפרדים מ-RESPONDER_CLIENT_*
#
# שלב 3 — הזדהות:
#   POST https://api.schooler.biz/oauth/token
#   Body: grant_type=password, client_id, client_secret, user_id, user_secret
#   תגובה: access_token, refresh_token, expires_in, created_at
#   רענון: grant_type=refresh_token + client_id + client_secret + refresh_token
#   בקשות API: Authorization: Bearer <access_token>
#
# בדיקה: npm run schooler:oauth
# SCHOOLER_USER_ID=your@email.com
# SCHOOLER_USER_SECRET=
# SCHOOLER_CLIENT_ID=
# SCHOOLER_CLIENT_SECRET=

# Rav Messer API V2 — https://graph.responder.live/v2
# מדריך: https://support.responder.co.il/portal/he/kb/articles/%D7%A8%D7%91-%D7%9E%D7%A1%D7%A8-%D7%97%D7%99%D7%91%D7%95%D7%A8-api
# Swagger: https://app.swaggerhub.com/apis/Responder/responder/V2.0
#
# שלב 1 — User Token (פעם אחת):
#   הגדרות חשבון > חיבורים חיצוניים > הפעל "רב מסר" > העתק מהעין
#
# שלב 2 — Client ID + Secret (מתמיכה):
#   פנו ל-support@responder.co.il
#
# שלב 3 — הזדהות:
#   POST https://graph.responder.live/v2/oauth/token
#   Body: grant_type=client_credentials, scope=*, client_id, client_secret, user_token
#   תגובה: שדה token (לא access_token) + expire (Unix)
#   בקשות API: Authorization: Bearer <token>
#
# בדיקה: node scripts/responder-oauth.mjs
# RESPONDER_CLIENT_ID=238
# RESPONDER_CLIENT_SECRET=
# RESPONDER_USER_TOKEN=

# Supadata — כתוביות YouTube בסביבת ענן (מומלץ לפריסה ב-Render)
# https://supadata.ai
# SUPADATA_API_KEY=
# SUPADATA_FIRST=true
