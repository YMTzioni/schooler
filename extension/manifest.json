{
  "manifest_version": 3,
  "name": "Schooler Lesson Importer",
  "version": "1.0.6",
  "description": "ייבוא פרקים ושיעורים עם קישורי הטמעה לדף עריכת קורס ב-Schooler",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["https://my.schooler.biz/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "ייבוא פרקים ושיעורים ל-Schooler",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://my.schooler.biz/t/*/s/*/*/edit*"],
      "js": ["selectors.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
