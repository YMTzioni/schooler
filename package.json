{
  "name": "schooler",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:web": "vite",
    "dev:api": "node server.js",
    "dev": "concurrently -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "api": "node server.js",
    "start": "npm run dev",
    "start:prod": "node server.js",
    "build": "npm run build:embed && vite build",
    "build:embed": "node scripts/build-schooler-embed.mjs",
    "build:mediaelement-poc": "node scripts/build-mediaelement-poc.mjs",
    "vercel-build": "npm run build",
    "lint": "oxlint",
    "preview": "vite preview",
    "responder:oauth": "node scripts/responder-oauth.mjs",
    "schooler:oauth": "node scripts/schooler-oauth.mjs"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "plyr": "^3.8.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "youtube-transcript": "^1.3.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^10.0.3",
    "esbuild": "^0.25.12",
    "oxlint": "^1.71.0",
    "typescript": "^5.9.3",
    "vite": "^5.4.19"
  }
}
